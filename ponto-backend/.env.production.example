# ===========================================
# DEPLOY - BACKEND (Render)
# ===========================================
# Crie um Web Service no Render (render.com)
# Runtime: Node
# Build Command: npm install && npm run build
# Start Command: npm start

# ===========================================
# DEPLOY - FRONTEND (Vercel)
# ===========================================
# Conecte o repositório no Vercel (vercel.com)
# Framework: Vite
# Build Command: npm run build
# Output Directory: dist

# ===========================================
# BANCO DE DADOS - SUPABASE
# ===========================================
# Use o PostgreSQL do Supabase
# Connection string está em Settings > Connection String

# ===========================================
# VARIÁVEIS DE PRODUÇÃO - BACKEND
# ===========================================
DATABASE_URL=postgres://user:password@host:5432/dbname
JWT_SECRET=generate-a-secure-random-string-here
JWT_REFRESH_SECRET=another-secure-random-string
VAPID_PUBLIC_KEY=web-push-public-key
VAPID_PRIVATE_KEY=web-push-private-key
PORT=3001
FRONTEND_URL=https://your-frontend.vercel.app

# ===========================================
# VARIÁVEIS DE PRODUÇÃO - FRONTEND
# ===========================================
VITE_API_URL=https://your-backend.onrender.com/api
VITE_VAPID_PUBLIC_KEY=web-push-public-key
